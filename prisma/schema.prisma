generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  USER
  ADMIN
}

model User {
  id                 String      @id @default(cuid())
  email              String      @unique
  displayName        String?
  phone              String?
  photoUrl           String?
  passwordHash       String
  tempPasswordPlain  String?
  emailVerified      Boolean     @default(false)
  role               Role        @default(USER)
  mustChangePassword Boolean     @default(false)
  resetCode          String?
  resetCodeExpiry    DateTime?
  resetVerified      Boolean     @default(false)
  isActive           Boolean     @default(true)
  gender             Gender?
  birthYear          Int?
  region             Region?
  membership         Membership?
  bookmarks          Bookmark[]
  notes              Note[]
  watchProgress      WatchProgress[]
  playbookAchievements PlaybookAchievement[]
  createdAt          DateTime    @default(now())
  updatedAt          DateTime    @updatedAt
}

model Bookmark {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, lessonId])
  @@index([userId])
}

model Podcast {
  id              String   @id @default(cuid())
  title           String
  description     String
  audioKey        String
  thumbnailKey    String
  season          Int      @default(1)
  episodeOrder    Int      @default(0)
  durationSeconds Int      @default(0)
  durationLabel   String   @default("")
  popular         Boolean  @default(false)
  industryId      String
  industry        Industry @relation(fields: [industryId], references: [id])
  publishedAt     DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([season, episodeOrder])
  @@index([popular])
  @@index([industryId])
}

model WatchProgress {
  id              String    @id @default(cuid())
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId        String
  lesson          Lesson    @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  currentSeconds  Int       @default(0)
  durationSeconds Int       @default(0)
  completedAt     DateTime?
  lastWatchedAt   DateTime  @default(now())
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@unique([userId, lessonId])
  @@index([userId, lastWatchedAt])
}

model Note {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  lessonId  String
  lesson    Lesson   @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, lessonId])
  @@index([userId])
}

model PlaybookAchievement {
  id          String    @id @default(cuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  videoId     String
  video       Video     @relation(fields: [videoId], references: [id], onDelete: Cascade)
  achievedAt  DateTime  @default(now())
  emailSentAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([userId, videoId])
  @@index([userId, achievedAt])
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum Region {
  YANGON
  MANDALAY
  THAILAND
  OTHER
}

model Membership {
  id                String           @id @default(cuid())
  userId            String           @unique
  user              User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  status            MembershipStatus @default(PENDING)
  plan              MembershipPlan?
  paymentMethod     PaymentMethod?
  paymentScreenshot String?
  amountMmk         Int              @default(0)
  approvedAt        DateTime?
  expiresAt         DateTime?
  notes             String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model MembershipSubmission {
  id              String           @id @default(cuid())
  fullName        String
  email           String
  phone           String
  plan            MembershipPlan   @default(SIX_MONTHS)
  paymentMethod   PaymentMethod
  amountMmk       Int
  screenshotKey   String
  note            String?
  status          SubmissionStatus @default(PENDING)
  adminNote       String?
  reviewedAt      DateTime?
  reviewedById    String?
  resultingUserId String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([status, createdAt])
}

enum MembershipPlan {
  SIX_MONTHS
  TWELVE_MONTHS
}

enum SubmissionStatus {
  PENDING
  APPROVED
  REJECTED
}

enum MembershipStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  KBZ_PAY
  WAVE_MONEY
}

enum ContentType {
  VIDEO
  PODCAST
}

enum Playbook {
  CEO_PLAYBOOK
}

model Industry {
  id        String    @id @default(cuid())
  name      String    @unique
  order     Int       @default(0)
  videos    Video[]
  podcasts  Podcast[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([order])
}

model Skillset {
  id        String   @id @default(cuid())
  name      String   @unique
  order     Int      @default(0)
  videos    Video[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([order])
}

enum PublishStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model Video {
  id                  String         @id @default(cuid())
  type                ContentType    @default(VIDEO)
  playbook            Playbook       @default(CEO_PLAYBOOK)
  industryId          String
  industry            Industry       @relation(fields: [industryId], references: [id])
  skillsetId          String
  skillset            Skillset       @relation(fields: [skillsetId], references: [id])
  titleLine1          String
  titleLine2          String?
  description         String
  instructorId        String
  instructor          Instructor     @relation(fields: [instructorId], references: [id])
  thumbnailKey        String
  trailerKey          String?
  guidebookKey        String?
  durationSeconds     Int            @default(0)
  durationLabel       String
  status              PublishStatus  @default(DRAFT)
  publishedAt         DateTime?
  lessons             Lesson[]
  skillsetItems       SkillsetItem[]
  playbookAchievements PlaybookAchievement[]
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
}

model Instructor {
  id                  String   @id @default(cuid())
  name                String
  title               String
  photoKey            String
  biographyParagraphs String[]
  videos              Video[]
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
}

model Lesson {
  id              String     @id @default(cuid())
  videoId         String
  video           Video      @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order           Int
  title           String
  videoKey        String
  durationSeconds Int        @default(0)
  durationLabel   String
  details         String
  bookmarks       Bookmark[]
  notes           Note[]
  watchProgress   WatchProgress[]
}

model SkillsetItem {
  id          String @id @default(cuid())
  videoId     String
  video       Video  @relation(fields: [videoId], references: [id], onDelete: Cascade)
  order       Int
  title       String
  description String
  imageKey    String
}
